{
  "name": "react-native-security-shield",
  "version": "1.0.1",
  "description": "Secure React Native package for SSL pinning, signature validation, emulator/debug/frida/root detection, and screenshot protection.",
  "main": "index.js",
  "types": "src/types.ts",
  "react-native": "index.js",
  "files": [
    "index.js",
    "src",
    "android",
    "ios",
    "scripts",
    "README.md",
    "LICENSE",
    "react-native-security-shield.podspec"
  ],
  "keywords": [
    "react-native",
    "security",
    "ssl-pinning",
    "frida-detection",
    "root-detection",
    "emulator-detection",
    "signature-validation",
    "screenshot-protection",
    "tamper-detection"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahsan-K/react-native-security-shield.git"
  },
  "homepage": "https://github.com/ahsan-K/react-native-security-shield#readme",
  "bugs": {
    "url": "https://github.com/ahsan-K/react-native-security-shield/issues"
  },
  "author": "ahsankk",
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.71.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "encode-pins": "node scripts/encodePins.js",
    "generate-native-config": "node scripts/generateNativeConfig.js",
    "postinstall-helper": "node scripts/postinstall.js",
    "prepare-security": "npm run generate-native-config && npm run encode-pins"
  }
}
